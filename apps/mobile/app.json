{
  "expo": {
    "name": "HeartPrevention",
    "slug": "heart-prevention",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "heartprevention",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#DC2626"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.heartprevention.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to photograph your blood test reports and imaging results.",
        "NSPhotoLibraryUsageDescription": "We need photo library access so you can upload existing photos of your reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DC2626"
      },
      "package": "com.heartprevention.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HeartPrevention to access your camera to photograph medical reports."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HeartPrevention to access your photos to upload medical reports."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
